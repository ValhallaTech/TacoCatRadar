{
  "name": "TacoCatRadar",
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "dev": "parcel serve src/index.html src/solve.html src/code.html",
    "build": "parcel build src/index.html src/solve.html src/code.html --dist-dir dist",
    "clean": "rimraf dist .parcel-cache",
    "lint": "eslint src/js/Palindrome.js src/js/DarkModeToggle.js src/js/CodeDisplay.js"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "7.0.0",
    "@popperjs/core": "2.11.8",
    "bootstrap": "5.3.3",
    "canvas-confetti": "1.9.3",
    "prismjs": "1.29.0",
    "sweetalert2": "11.14.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.2.0",
    "globals": "17.4.0",
    "parcel": "2.16.0",
    "rimraf": "6.0.1"
  },
  "resolutions": {
    "glob": "13.0.6",
    "minimatch": "10.2.5",
    "picomatch": "4.0.4"
  }
}
