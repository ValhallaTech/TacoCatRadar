{
  "name": "TacoCatRadar",
  "type": "module",
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "dev": "parcel serve src/index.html src/solve.html src/code.html",
    "build": "parcel build src/index.html src/solve.html src/code.html --dist-dir dist && cp src/robots.txt dist/robots.txt",
    "clean": "rimraf dist .parcel-cache",
    "lint": "eslint src/js/Palindrome.js src/js/DarkModeToggle.js src/js/CodeDisplay.js"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "7.2.0",
    "@popperjs/core": "2.11.8",
    "bootstrap": "5.3.8",
    "canvas-confetti": "1.9.4",
    "prismjs": "1.30.0",
    "sweetalert2": "11.26.24"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@parcel/packager-raw-url": "2.16.4",
    "@parcel/transformer-webmanifest": "2.16.4",
    "eslint": "10.2.1",
    "globals": "17.5.0",
    "parcel": "2.16.4",
    "rimraf": "6.1.3"
  },
  "resolutions": {
    "glob": "13.0.6",
    "minimatch": "10.2.5",
    "picomatch": "4.0.4"
  }
}
