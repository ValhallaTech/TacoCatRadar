{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "groupName": "all dependencies",
      "automerge": true,
      "automergeType": "pr",
      "matchPackageNames": ["*"]
    }
  ],
  "enabledManagers": ["npm", "github-actions"],
  "rangeStrategy": "update-lockfile"
}
